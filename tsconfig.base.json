{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@kairos3d/cesium": ["./packages/kairos3d-cesium/src/index.ts"],
      "@kairos3d/cesium/*": ["./packages/kairos3d-cesium/src/*/index.ts"],
      "@kairos3d/cesium-widget": ["./packages/kairos3d-cesium-widget/src/index.ts"],
      "@kairos3d/cesium-widget/*": ["./packages/kairos3d-cesium-widget/src/*/index.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  }
}
