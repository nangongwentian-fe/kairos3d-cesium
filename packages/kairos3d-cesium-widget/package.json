{
  "name": "@kairos3d/cesium-widget",
  "version": "0.0.0",
  "description": "Framework-neutral widget runtime for Kairos3D Cesium applications.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./snapshot": {
      "types": "./dist/snapshot/index.d.ts",
      "import": "./dist/snapshot/index.js",
      "require": "./dist/snapshot/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@kairos3d/cesium": "workspace:*"
  },
  "devDependencies": {
    "@kairos3d/cesium": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
